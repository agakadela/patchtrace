{
  "name": "patchtrace",
  "version": "0.0.0",
  "private": true,
  "description": "Local-first CLI for evidence-backed AI-agent patch verification briefs.",
  "type": "module",
  "packageManager": "pnpm@10.2.0",
  "bin": {
    "patchtrace": "./dist/cli/index.js"
