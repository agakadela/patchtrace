diff --git a/tests/api/projects.test.ts b/tests/api/projects.test.ts
index 0ed9172..fe2ac81 100644
--- a/tests/api/projects.test.ts
+++ b/tests/api/projects.test.ts
@@ -1,8 +1,44 @@
 import { describe, expect, it, vi } from "vitest";
 
 import { PATCH } from "@/app/api/projects/[projectId]/route";
+import { getSessionUser } from "@/src/lib/auth/session";
 import { updateProject } from "@/src/lib/projects";
 
+vi.mock("@/src/lib/auth/session", () => ({
+  getSessionUser: vi.fn(),
+}));
+
 vi.mock("@/src/lib/projects", () => ({
   updateProject: vi.fn(),
 }));
+
+describe("PATCH /api/projects/:projectId", () => {
+  it("renames a project for a signed-in user", async () => {
+    vi.mocked(getSessionUser).mockResolvedValue({ id: "user_123" });
+    vi.mocked(updateProject).mockResolvedValue({
+      id: "project_123",
+      name: "Launch plan",
+    });
+
+    const response = await PATCH(
+      new Request("https://app.test/api/projects/project_123", {
+        method: "PATCH",
+        body: JSON.stringify({ name: "Launch plan" }),
+      }),
+      { params: { projectId: "project_123" } },
+    );
+
+    expect(response.status).toBe(200);
+    expect(updateProject).toHaveBeenCalledWith({
+      projectId: "project_123",
+      userId: "user_123",
+      name: "Launch plan",
+    });
+  });
+
+  it("returns 401 without a session", async () => {
+    vi.mocked(getSessionUser).mockResolvedValue(null);
+
+    const response = await PATCH(new Request("https://app.test/api/projects/project_123"), {
+      params: { projectId: "project_123" },
+    });
+
+    expect(response.status).toBe(401);
+  });
+});
