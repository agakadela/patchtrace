--- /dev/null
+++ b/src/lib/auth/session.ts
@@ -0,0 +1,13 @@
+import { auth } from "@/src/lib/auth/provider";
+
+export async function getSessionUser(): Promise<{ id: string } | null> {
+  const session = await auth();
+
+  if (!session?.user?.id) {
+    return null;
+  }
+
+  return {
+    id: session.user.id,
+  };
+}
