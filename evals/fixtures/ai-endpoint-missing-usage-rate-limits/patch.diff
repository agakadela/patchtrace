@@ -0,0 +1,25 @@
+import { describe, expect, it, vi } from "vitest";
+
+import { POST } from "@/app/api/ai/ticket-summary/route";
+import { summarizeTicket } from "@/src/lib/ai/provider";
+
+vi.mock("@/src/lib/ai/provider", () => ({
+  summarizeTicket: vi.fn().mockResolvedValue("Customer needs a refund follow-up."),
+}));
+
+describe("POST /api/ai/ticket-summary", () => {
+  it("returns a generated summary", async () => {
+    const response = await POST(
+      new Request("https://app.test/api/ai/ticket-summary", {
+        method: "POST",
+        body: JSON.stringify({
+          ticketId: "ticket_123",
+          transcript: "The customer says they were double charged.",
+        }),
+      }),
+    );
+
+    await expect(response.json()).resolves.toEqual({
+      summary: "Customer needs a refund follow-up.",
+    });
+  });
+});
