@@ -1,8 +1,38 @@
 import { describe, expect, it, vi } from "vitest";
 
 import { POST } from "@/app/api/stripe/webhook/route";
+import { grantPaidAccess } from "@/src/lib/billing/entitlements";
 
 vi.mock("@/src/lib/stripe", () => ({
   stripe: {
     webhooks: {
       constructEvent: vi.fn(),
     },
   },
 }));
+
+vi.mock("@/src/lib/billing/entitlements", () => ({
+  grantPaidAccess: vi.fn(),
+}));
+
+describe("POST /api/stripe/webhook", () => {
+  it("grants paid access for checkout.session.completed", async () => {
+    const response = await POST(buildStripeRequest("evt_123", "checkout.session.completed"));
+
+    expect(response.status).toBe(200);
+    expect(grantPaidAccess).toHaveBeenCalledWith({
+      customerId: "cus_123",
+      userId: "user_123",
+    });
+  });
+
+  it("does not grant paid access twice for the same event", async () => {
+    await POST(buildStripeRequest("evt_duplicate", "checkout.session.completed"));
+    const duplicateResponse = await POST(buildStripeRequest("evt_duplicate", "checkout.session.completed"));
+
+    expect(duplicateResponse.status).toBe(200);
+    expect(grantPaidAccess).toHaveBeenCalledTimes(1);
+  });
+});
