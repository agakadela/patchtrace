diff --git a/src/lib/billing/stripe-events.ts b/src/lib/billing/stripe-events.ts
new file mode 100644
index 0000000..e213f9d
--- /dev/null
+++ b/src/lib/billing/stripe-events.ts
@@ -0,0 +1,19 @@
+import { db } from "@/src/lib/db";
+
+export async function hasProcessedEvent(eventId: string): Promise<boolean> {
+  const existing = await db.stripeEvent.findFirst({
+    where: { eventId },
+  });
+
+  return existing !== null;
+}
+
+export async function markEventProcessed(eventId: string): Promise<void> {
+  await db.stripeEvent.create({
+    data: {
+      eventId,
+      processedAt: new Date(),
+    },
+  });
+}
