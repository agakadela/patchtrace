# Example environment file. Never put real secrets here.
# PatchTrace Python V0 should not require environment variables.

# Local CLI behavior
PATCHTRACE_HOME=.patchtrace
PATCHTRACE_LOG_LEVEL=info

# Optional future AI integration. Leave empty in V0.
AI_PROVIDER_API_KEY=
AI_COST_CAP_DAILY=
AI_RETRY_CAP=
