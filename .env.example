# Example environment file. Never put real secrets here.
# Copy to .env.local / .env and fill values in your local environment only.

# App
APP_ENV=local
APP_URL=http://localhost:3000

# Database
DATABASE_URL=postgres://user:password@localhost:5432/app_local

# Auth/session
AUTH_SECRET=replace-with-local-dev-secret
AUTH_PROVIDER_URL=
AUTH_PROVIDER_CLIENT_ID=
AUTH_PROVIDER_CLIENT_SECRET=

# Payments, if triggered
PAYMENT_PROVIDER_SECRET_KEY=
PAYMENT_WEBHOOK_SECRET=

# AI, if triggered
AI_PROVIDER_API_KEY=
AI_COST_CAP_DAILY=
AI_RETRY_CAP=

# Observability
SENTRY_DSN=
LOG_LEVEL=debug

# External integrations, if triggered
INTEGRATION_PROVIDER_API_KEY=
INTEGRATION_WEBHOOK_SECRET=
